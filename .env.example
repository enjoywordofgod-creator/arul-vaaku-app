# .env.example
# Copy this file to `.env` and update values as needed before running the server.
# Admin login credentials (defaults in code to admin/admin123 if left blank):
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# Secret used to sign JWT tokens for admin authentication. Change to a
# long, random string in production.
JWT_SECRET=your_jwt_secret_key

# Optional: Port the Express server listens on (3000 if undefined)
PORT=3000
